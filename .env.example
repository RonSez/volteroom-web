# Copy to .env.local for local dev. On Cloudflare, set these in the
# Workers project (Settings -> Variables & Secrets). The two NEXT_PUBLIC_*
# vars are read at BUILD time (next.config.ts uses the URL for next/image),
# so add them as plain build variables. The service-role key is a runtime
# SECRET — never expose it to the browser.

# --- Supabase (required by the deployed app) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Local maintenance scripts only (db:migrate / seed) ---
# Not needed on Cloudflare at runtime.
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
